<Window x:Class="DevSprint.UI.Views.JiraSignInDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DevSprint.UI.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:JiraSignInViewModel}"
        Style="{StaticResource FluentWindow}"
        Title="Sign in to Jira"
        Width="460" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{StaticResource SurfaceBrush}" Padding="28,24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Sign in to Jira"
                       FontSize="20" FontWeight="SemiBold"
                       FontFamily="{StaticResource ContentFont}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>

            <TextBlock Grid.Row="1"
                       Text="DevSprint is opening Atlassian's sign-in page in your default browser. Approve the requested access, then return here."
                       FontSize="13"
                       FontFamily="{StaticResource ContentFont}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <!-- Status line -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⟳"
                           FontSize="14"
                           FontFamily="{StaticResource ContentFont}"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsWorking, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="JiraStatusSpinner" CenterX="7" CenterY="7"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="JiraStatusSpinner"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:1"
                                                     RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontFamily="{StaticResource ContentFont}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource CompactLinkButton}"
                        Padding="14,6"
                        Margin="0,0,8,0"/>
                <Button Content="Open browser again"
                        Command="{Binding OpenBrowserAgainCommand}"
                        Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
