<Window x:Class="DevSprint.UI.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:DevSprint.UI.ViewModels"
xmlns:b="clr-namespace:DevSprint.UI.Behaviors"
mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
Style="{StaticResource FluentWindow}"
Title="Team Hub" Height="700" Width="1200">

    <Window.Resources>
        <DataTemplate x:Key="JiraIssueTemplate">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,6"
                    Padding="0" ClipToBounds="True" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectIssueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="5"
                            CornerRadius="4,0,0,4"
                            Background="{Binding IsCurrentSprint, Converter={StaticResource SprintBorderBrushConverter}}"/>
                    <Grid Margin="14,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.RowSpan="4"
                            Background="#EFF6FC" CornerRadius="4"
                            Padding="10,5" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   FontFamily="{StaticResource ContentFont}">
                            <Hyperlink NavigateUri="{Binding BrowseUrl}"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource AccentBrush}"
                                       TextDecorations="None">
                                <Run Text="{Binding Key, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding Summary}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource ContentFont}"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal"
                                Margin="0,4,0,0">
                        <TextBlock Text="{Binding Created, StringFormat='Created: {0:dd/MM/yyyy}'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Updated, StringFormat='Updated: {0:dd/MM/yyyy}'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Status}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="{Binding DaysInCurrentState, StringFormat='({0}d)'}"
                                   Margin="4,0,0,0" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding IssueType}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal"
                                Margin="0,6,0,0">
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                Background="{Binding HasDescription, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasDescription, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock Text="Description" FontSize="11" Foreground="White"
                                           FontFamily="{StaticResource ContentFont}"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                Background="{Binding HasAcceptanceCriteria, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasAcceptanceCriteria, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock Text="AC" FontSize="11" Foreground="White"
                                           FontFamily="{StaticResource ContentFont}"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Padding="8,3"
                                Background="{Binding HasComments, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasComments, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock FontSize="11" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="Comments"/>
                                    <Run Text="{Binding CommentCount, StringFormat='({0})', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Grid.Row="3"
                               Text="{Binding StateHistory, Converter={StaticResource StateHistoryConverter}}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource ContentFont}"
                               Margin="0,5,0,0" TextWrapping="Wrap"/>

                    <StackPanel Grid.Column="2" Grid.RowSpan="4"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Margin="14,0,0,0">
                        <TextBlock Text="{Binding StoryPoints, StringFormat='{}{0} SP'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="{Binding TimeSpent, TargetNullValue='-', FallbackValue='-'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource ContentFont}"/>
                    </StackPanel>
                </Grid>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Team Hub" FontSize="32" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource ContentFont}" VerticalAlignment="Center"/>
            <TextBlock Text="⟳" FontSize="20" Margin="20,0,0,0"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                       FontFamily="{StaticResource ContentFont}">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" CenterX="10" CenterY="10"/>
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360"
                                                 Duration="0:0:1"
                                                 RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- Search box -->
            <Grid Margin="40,0,0,0" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Width="250" Padding="10,8,32,8"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource ContentFont}" FontSize="13"/>
                <TextBlock Text="🔍" FontSize="14" IsHitTestVisible="False"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   TextWrapping="Wrap" FontFamily="{StaticResource ContentFont}" FontSize="13"/>

        <TextBlock Grid.Row="2" Text="Loading…" FontSize="14"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontFamily="{StaticResource ContentFont}"
                   Margin="0,0,0,8"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <TabControl x:Name="MainTabControl" Grid.Row="3" Style="{StaticResource OutlookTabControl}">

            <!-- Product Backlog -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Product Backlog">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                            <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                <Run Text="Total:"/> <Run Text="{Binding BacklogTotalCount, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <Border Background="#E8A317" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                            <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                <Run Text="Refined:"/> <Run Text="{Binding BacklogRefinedCount, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <Border Background="#6B5B95" CornerRadius="4" Padding="12,6">
                            <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                <Run Text="In Analysis:"/> <Run Text="{Binding BacklogInAnalysisCount, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                    <ScrollViewer x:Name="BacklogScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding BacklogIssues}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding BacklogStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Current Sprint -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Current Sprint">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding SprintName}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="{StaticResource ContentFont}" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding SprintDateRange}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                                <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="Story Points:"/> <Run Text="{Binding SprintTotalStoryPoints, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding SprintStateSummary}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer x:Name="SprintScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding SprintIssues}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding SprintStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Assigned To Me -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Assigned To Me">
                <DockPanel Margin="0,12,0,0">
                    <ScrollViewer x:Name="AssignedScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding AssignedIssues}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding AssignedStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Contributing To -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Contributing To">
                <DockPanel Margin="0,12,0,0">
                    <ScrollViewer x:Name="ContributingScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding ContributingIssues}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding ContributingStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Right Sidebar -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                HorizontalAlignment="Right"
                Width="380"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsSidebarOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="10">
            <Grid Margin="20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with close button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <Button DockPanel.Dock="Right" Content="✕" 
                            Command="{Binding CloseSidebarCommand}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                            Cursor="Hand" Padding="8,4"
                            VerticalAlignment="Top"/>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedIssue.Key}" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource ContentFont}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedIssue.Summary}" FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"
                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Sidebar Tabs -->
                <TabControl Grid.Row="2" Style="{StaticResource OutlookTabControl}">
                    <TabItem Style="{StaticResource OutlookTabItem}" Header="Team Members">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding SidebarTeamMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SubtleFillBrush}"
                                                CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="32" Height="32" CornerRadius="16"
                                                        Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Name[0]}" FontSize="14"
                                                               Foreground="White" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                    <TextBlock Text="{Binding Role}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Style="{StaticResource OutlookTabItem}" Header="Code">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding SidebarBranches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SubtleFillBrush}"
                                                CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontFamily="{StaticResource ContentFont}"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Repository}" FontSize="11"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                    <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LastCommitSha}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="Consolas, Courier New"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding LastCommitAuthor}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                    <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LastCommitDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Sidebar loading indicator -->
                <TextBlock Grid.Row="2" Text="Loading…" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="{StaticResource ContentFont}"
                           HorizontalAlignment="Center" Margin="0,20,0,0"
                           Visibility="{Binding IsSidebarLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                           Panel.ZIndex="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
