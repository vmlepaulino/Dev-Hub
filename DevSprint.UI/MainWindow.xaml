<Window x:Class="DevSprint.UI.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="clr-namespace:DevSprint.UI.ViewModels"
xmlns:b="clr-namespace:DevSprint.UI.Behaviors"
mc:Ignorable="d"
d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
Style="{StaticResource FluentWindow}"
Title="Team Hub" Height="700" Width="1200">

    <Window.Resources>
        <!-- Teams icon (vector, stylized official mark) -->
        <DrawingImage x:Key="TeamsIconImage">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <!-- main purple circle -->
                    <GeometryDrawing Brush="#6264A7">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="10,10" RadiusX="9" RadiusY="9"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- white 'T' glyph -->
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="6,6,8,3" RadiusX="1" RadiusY="1"/>
                                <RectangleGeometry Rect="9.5,9,1,6" RadiusX="0.8" RadiusY="0.8"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- small decorative circles to mimic Teams cluster -->
                    <GeometryDrawing Brush="#4B4F8E">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <EllipseGeometry Center="14.5,6.5" RadiusX="2" RadiusY="2"/>
                                <EllipseGeometry Center="15.5,12.5" RadiusX="1.4" RadiusY="1.4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>
        <DataTemplate x:Key="JiraIssueTemplate">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,6"
                    Padding="0" ClipToBounds="True" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.SelectIssueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"/>
                </Border.InputBindings>
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="5"
                            CornerRadius="4,0,0,4"
                            Background="{Binding IsCurrentSprint, Converter={StaticResource SprintBorderBrushConverter}}"/>
                    <Grid Margin="14,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Grid.RowSpan="4"
                            Background="#EFF6FC" CornerRadius="4"
                            Padding="10,5" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <TextBlock FontWeight="SemiBold" FontSize="12"
                                   FontFamily="{StaticResource ContentFont}">
                            <Hyperlink NavigateUri="{Binding BrowseUrl}"
                                       RequestNavigate="Hyperlink_RequestNavigate"
                                       Foreground="{StaticResource AccentBrush}"
                                       TextDecorations="None">
                                <Run Text="{Binding Key, Mode=OneWay}"/>
                            </Hyperlink>
                        </TextBlock>
                    </Border>

                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding Summary}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource ContentFont}"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal"
                                Margin="0,4,0,0">
                        <TextBlock Text="{Binding Created, StringFormat='Created: {0:dd/MM/yyyy}'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Updated, StringFormat='Updated: {0:dd/MM/yyyy}'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Status}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="{Binding DaysInCurrentState, StringFormat='({0}d)'}"
                                   Margin="4,0,0,0" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="·" Margin="8,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding IssueType}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal"
                                Margin="0,6,0,0">
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                Background="{Binding HasDescription, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasDescription, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock Text="Description" FontSize="11" Foreground="White"
                                           FontFamily="{StaticResource ContentFont}"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                Background="{Binding HasAcceptanceCriteria, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasAcceptanceCriteria, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock Text="AC" FontSize="11" Foreground="White"
                                           FontFamily="{StaticResource ContentFont}"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="4" Padding="8,3"
                                Background="{Binding HasComments, Converter={StaticResource BoolToSignalBrushConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding HasComments, Converter={StaticResource BoolToSignalIconConverter}}"
                                           FontSize="11" FontWeight="Bold" Foreground="White" Margin="0,0,4,0"/>
                                <TextBlock FontSize="11" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="Comments"/>
                                    <Run Text="{Binding CommentCount, StringFormat='({0})', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Grid.Row="3"
                               Text="{Binding StateHistory, Converter={StaticResource StateHistoryConverter}}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource ContentFont}"
                               Margin="0,5,0,0" TextWrapping="Wrap"/>

                    <StackPanel Grid.Column="2" Grid.RowSpan="4"
                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                Margin="14,0,0,0">
                        <TextBlock Text="{Binding StoryPoints, StringFormat='{}{0} SP'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource ContentFont}"/>
                        <TextBlock Text="{Binding TimeSpent, TargetNullValue='-', FallbackValue='-'}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   FontFamily="{StaticResource ContentFont}"/>
                    </StackPanel>
                </Grid>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="32,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Team Hub" FontSize="24" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource ContentFont}" VerticalAlignment="Center"/>
            <TextBlock Text="⟳" FontSize="16" Margin="14,0,0,0"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                       FontFamily="{StaticResource ContentFont}">
                <TextBlock.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate" CenterX="10" CenterY="10"/>
                </TextBlock.RenderTransform>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                 Storyboard.TargetProperty="Angle"
                                                 From="0" To="360"
                                                 Duration="0:0:1"
                                                 RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- Search box -->
            <Grid Margin="24,0,0,0" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Width="220" Padding="8,5,28,5"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{StaticResource ContentFont}" FontSize="12">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Text="🔍" FontSize="12" IsHitTestVisible="False"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Grid>

            <!-- Current user name -->
            <TextBlock Text="{Binding CurrentUserDisplayName}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="{StaticResource ContentFont}"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>

            <!-- GitHub sign-out -->
            <Button Content="Sign out of GitHub"
                    Command="{Binding SignOutGitHubCommand}"
                    Style="{StaticResource CompactLinkButton}"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Clear cached GitHub tokens. The next GitHub action will prompt for sign-in."
                    Visibility="{Binding IsGitHubSignedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Jira sign-out -->
            <Button Content="Sign out of Jira"
                    Command="{Binding SignOutJiraCommand}"
                    Style="{StaticResource CompactLinkButton}"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Clear cached Jira tokens. The next Jira action will prompt for sign-in."
                    Visibility="{Binding IsJiraSignedIn, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Reconfigure -->
            <Button Content="Reconfigure…"
                    Command="{Binding ReconfigureCommand}"
                    Style="{StaticResource CompactLinkButton}"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="Edit your Backlog Management and Code Repository settings. Changes apply on next launch."/>
        </StackPanel>

        <!-- First-run welcome banner -->
        <Border Grid.Row="1" Background="{StaticResource AccentBrush}" CornerRadius="6"
                Padding="16,12" Margin="0,0,0,8"
                Visibility="{Binding IsFirstRun, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Welcome! Your display name:" FontSize="13"
                           Foreground="White" FontFamily="{StaticResource ContentFont}"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding WelcomeName, UpdateSourceTrigger=PropertyChanged}"
                         Width="180" Margin="12,0,12,0" Padding="6,4"
                         FontFamily="{StaticResource ContentFont}" FontSize="13"/>
                <Button Content="Confirm" Command="{Binding ConfirmWelcomeCommand}"
                        Style="{StaticResource AccentButton}" Padding="12,4"
                        FontSize="12"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,4"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   TextWrapping="Wrap" FontFamily="{StaticResource ContentFont}" FontSize="13"/>

        <TextBlock Grid.Row="3" Text="Loading…" FontSize="12"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontFamily="{StaticResource ContentFont}"
                   Margin="0,0,0,4"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <TabControl x:Name="MainTabControl" Grid.Row="4" Style="{StaticResource OutlookTabControl}">

            <!-- Product Backlog -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Product Backlog">
                <DockPanel Margin="0,12,0,0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: clickable state-filter badges. Inactive ones are faded. -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Total: clears state filter. Always shows full opacity when no filter is active. -->
                            <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                                    Background="{StaticResource AccentBrush}"
                                    ToolTip="Show all backlog items">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetBacklogStateFilterCommand}"
                                                  CommandParameter=""/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0.55"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BacklogStateFilter}" Value="">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="Total:"/> <Run Text="{Binding BacklogTotalCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <!-- Refined: toggle filter to issues whose status contains "refin" or "ready". -->
                            <Border CornerRadius="4" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"
                                    Background="#E8A317"
                                    ToolTip="Filter to refined / ready items">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetBacklogStateFilterCommand}"
                                                  CommandParameter="Refined"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0.55"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BacklogStateFilter}" Value="Refined">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="Refined:"/> <Run Text="{Binding BacklogRefinedCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <!-- In Analysis: toggle filter to issues whose status contains "analy" or "review". -->
                            <Border CornerRadius="4" Padding="12,6" Cursor="Hand"
                                    Background="#6B5B95"
                                    ToolTip="Filter to in-analysis / review items">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding SetBacklogStateFilterCommand}"
                                                  CommandParameter="InAnalysis"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="0.55"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BacklogStateFilter}" Value="InAnalysis">
                                                <Setter Property="Opacity" Value="1"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                    <Run Text="In Analysis:"/> <Run Text="{Binding BacklogInAnalysisCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- Right: in-memory backlog search (filters at 3+ chars) -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <TextBox x:Name="BacklogSearchBox" Width="240" Padding="8,5,28,5"
                                     Text="{Binding BacklogFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource ContentFont}" FontSize="12"
                                     ToolTip="Search the backlog by issue ID or words in the title (starts at 3 characters)."/>
                            <TextBlock Text="🔍" FontSize="12" IsHitTestVisible="False"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </Grid>
                    <ScrollViewer x:Name="BacklogScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding BacklogView}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding BacklogStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Sprints -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Sprints">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox ItemsSource="{Binding AvailableSprints}"
                                      SelectedItem="{Binding SelectedSprint}"
                                      DisplayMemberPath="Name"
                                      Width="280" FontSize="13"
                                      FontFamily="{StaticResource ContentFont}"/>
                            <TextBlock Text="{Binding SprintDateRange}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: story-points badge -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="12,6" Margin="0,0,8,0">
                                    <TextBlock FontSize="12" Foreground="White" FontFamily="{StaticResource ContentFont}">
                                        <Run Text="Story Points:"/> <Run Text="{Binding SprintTotalStoryPoints, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- Right: in-memory sprint search (filters at 3+ chars) -->
                            <Grid Grid.Column="1" VerticalAlignment="Center">
                                <TextBox x:Name="SprintSearchBox" Width="240" Padding="8,5,28,5"
                                         Text="{Binding SprintFilterText, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource ContentFont}" FontSize="12"
                                         ToolTip="Search the sprint by issue ID or words in the title (starts at 3 characters)."/>
                                <TextBlock Text="🔍" FontSize="12" IsHitTestVisible="False"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Grid>
                        </Grid>
                        <TextBlock Text="{Binding SprintStateSummary}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource ContentFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer x:Name="SprintScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding SprintView}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding SprintStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Assigned To Me -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Assigned To Me">
                <DockPanel Margin="0,12,0,0">
                    <ScrollViewer x:Name="AssignedScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding AssignedView}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding AssignedStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Contributing To -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Contributing To">
                <DockPanel Margin="0,12,0,0">
                    <ScrollViewer x:Name="ContributingScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding ContributingView}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="JiraIssueTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding ContributingStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       HorizontalAlignment="Center" Margin="0,8,0,12"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Team -->
            <TabItem Style="{StaticResource OutlookTabItem}" Header="Team">
                <DockPanel Margin="0,12,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                        <ItemsControl ItemsSource="{Binding TeamMembers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SubtleFillBrush}"
                                            CornerRadius="6" Padding="14,12" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    Background="{StaticResource AccentBrush}" Margin="0,0,14,0">
                                                <TextBlock Text="{Binding DisplayName[0]}" FontSize="15"
                                                           Foreground="White" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontFamily="{StaticResource ContentFont}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontFamily="{StaticResource ContentFont}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Email}" FontSize="11"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontFamily="{StaticResource ContentFont}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding JiraDisplayName}" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontFamily="{StaticResource ContentFont}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Teams chat button -->
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource TeamsIconButton}"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.OpenTeamsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Open in Teams">
                                                <Image Width="18" Height="18" Source="{StaticResource TeamsIconImage}" Stretch="Uniform" SnapsToDevicePixels="True"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>

        <!-- Right Sidebar -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                HorizontalAlignment="Right"
                Width="540"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding IsSidebarOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="10">
            <Grid Margin="20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with close button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <Button DockPanel.Dock="Right" Content="✕" 
                            Command="{Binding CloseSidebarCommand}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                            Cursor="Hand" Padding="8,4"
                            VerticalAlignment="Top"/>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedIssue.Key}" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource ContentFont}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedIssue.Summary}" FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource ContentFont}"
                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Sidebar Tabs -->
                <TabControl Grid.Row="2" Style="{StaticResource OutlookTabControl}">
                    <TabItem Style="{StaticResource CompactOutlookTabItem}" Header="People">
                        <DockPanel Margin="0,12,0,0">
                            <Button DockPanel.Dock="Top"
                                    Style="{StaticResource TeamsGroupButton}"
                                    Command="{Binding OpenTeamsGroupCommand}"
                                    ToolTip="Start a Teams group chat with the people you've selected below"
                                    AutomationProperties.Name="Start Teams group chat">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Width="18" Height="18" Source="{StaticResource TeamsIconImage}" Stretch="Uniform" SnapsToDevicePixels="True"/>
                                    <TextBlock Text="Start group chat with selected"
                                               Margin="8,0,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource ContentFont}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource SubtleFillBrush}"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding IsGitHubLinkOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding GitHubMemberToLink.GitHubUsername, StringFormat='Link GitHub user: {0}'}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource ContentFont}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding TeamMembers}"
                                                  SelectedItem="{Binding SelectedIdentityForGitHubLink}"
                                                  DisplayMemberPath="DisplayName"
                                                  MinWidth="190"
                                                  FontFamily="{StaticResource ContentFont}"
                                                  FontSize="12"/>
                                        <Button Grid.Column="1"
                                                Content="Save"
                                                Style="{StaticResource AccentButton}"
                                                Command="{Binding LinkGitHubMemberCommand}"
                                                Padding="10,5"
                                                FontSize="12"
                                                Margin="8,0,0,0"/>
                                        <Button Grid.Column="2"
                                                Content="Cancel"
                                                Style="{StaticResource CompactLinkButton}"
                                                Command="{Binding CancelGitHubLinkCommand}"
                                                Margin="6,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                <ItemsControl ItemsSource="{Binding SidebarPeople}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SubtleFillBrush}"
                                                    CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Selection checkbox -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsSelectedForChat, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,10,0"
                                                              ToolTip="Include this person in the group chat"/>

                                                    <!-- Avatar bubble -->
                                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="16"
                                                            Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding DisplayName[0]}" FontSize="14"
                                                                   Foreground="White" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   FontFamily="{StaticResource ContentFont}"/>
                                                    </Border>

                                                    <!-- Name + email + tags (stacked) -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Email}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding Email, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border CornerRadius="10" Padding="8,2" Margin="0,2,6,2">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <!-- Default: gray pill (Knowledge contributor) -->
                                                                                <Setter Property="Background" Value="#F2F2F2"/>
                                                                                <Setter Property="BorderBrush" Value="#BDBDBD"/>
                                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding}" Value="Team member">
                                                                                        <Setter Property="Background" Value="#EFF6FC"/>
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding}"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   FontFamily="{StaticResource ContentFont}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding}" Value="Team member">
                                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <!-- Action buttons -->
                                                    <StackPanel Grid.Column="3"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,0,0">
                                                        <Button Content="Link"
                                                                Style="{StaticResource CompactLinkButton}"
                                                                Command="{Binding DataContext.StartGitHubLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Link this GitHub username to a Jira teammate"
                                                                Visibility="{Binding CanLinkGitHubAccount, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <!-- Teams chat button (single person) -->
                                                        <Button Style="{StaticResource TeamsIconButton}"
                                                                Margin="6,0,0,0"
                                                                Command="{Binding DataContext.OpenTeamsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Open in Teams">
                                                            <Image Width="18" Height="18" Source="{StaticResource TeamsIconImage}" Stretch="Uniform" SnapsToDevicePixels="True"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>
                    <TabItem Style="{StaticResource CompactOutlookTabItem}" Header="Knowledge">
                        <DockPanel Margin="0,12,0,0">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding SidebarConfluenceStatus}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontFamily="{StaticResource ContentFont}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding SidebarConfluenceStatus, Converter={StaticResource StringToVisibilityConverter}}"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SidebarConfluencePages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SubtleFillBrush}"
                                                    CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontFamily="{StaticResource ContentFont}"
                                                               TextWrapping="Wrap">
                                                        <Hyperlink NavigateUri="{Binding WebUrl}"
                                                                   RequestNavigate="Hyperlink_RequestNavigate"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   TextDecorations="None">
                                                            <Run Text="{Binding Title, Mode=OneWay}"/>
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding SpaceName}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"/>
                                                        <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding Type}" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"/>
                                                        <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        <TextBlock Text="{Binding LastModified, StringFormat='Updated {0:dd/MM/yyyy}'}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Creator.DisplayName, StringFormat='Author: {0}'}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"
                                                                   Visibility="{Binding Creator.DisplayName, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Visibility="{Binding LastEditor.DisplayName, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding LastEditor.DisplayName, StringFormat='Last edited: {0}'}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontFamily="{StaticResource ContentFont}"
                                                                   Visibility="{Binding LastEditor.DisplayName, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding MatchReason}"
                                                               FontSize="11"
                                                               FontStyle="Italic"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontFamily="{StaticResource ContentFont}"
                                                               Margin="0,4,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding MatchReason, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>
                    <TabItem Style="{StaticResource CompactOutlookTabItem}" Header="Code">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                            <ItemsControl ItemsSource="{Binding SidebarBranches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SubtleFillBrush}"
                                                CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontFamily="{StaticResource ContentFont}"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Repository}" FontSize="11"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                    <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LastCommitSha}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="Consolas, Courier New"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding LastCommitAuthor}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                    <TextBlock Text="·" Margin="6,0" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding LastCommitDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontFamily="{StaticResource ContentFont}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Sidebar loading indicator -->
                <TextBlock Grid.Row="2" Text="Loading…" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontFamily="{StaticResource ContentFont}"
                           HorizontalAlignment="Center" Margin="0,20,0,0"
                           Visibility="{Binding IsSidebarLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                           Panel.ZIndex="5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
